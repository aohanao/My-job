from part import *
from material import *
from section import *
from assembly import *
from step import *
from interaction import *
from load import *
from mesh import *
from job import *
from sketch import *
from visualization import *
import os

# 1. 接收大模型 Agent 传递进来的动态参数
excavation_method = "{{ excavation_method }}"
anchor_length = {{ anchor_length }}
shotcrete_thickness = {{ shotcrete_thickness }} / 100.0  # 将 cm 转换为 m

print("=== CAE Agent 隧道自动建模启动 (新架构标准) ===")
print("开挖方法: ", excavation_method)
print("锚杆长度 (m): ", anchor_length)
print("初支厚度 (m): ", shotcrete_thickness)

# 2. 初始化模型
Mdb()
myModel = mdb.Model(name='Tunnel_Model')

# 3. 创建隧道截面草图 (标准半圆拱直墙)
s = myModel.ConstrainedSketch(name='__profile__', sheetSize=50.0)
s.Line(point1=(-5.0, 4.0), point2=(-5.0, 0.0))
s.Line(point1=(-5.0, 0.0), point2=(5.0, 0.0))
s.Line(point1=(5.0, 0.0), point2=(5.0, 4.0))
s.ArcByCenterEnds(center=(0.0, 4.0), point1=(5.0, 4.0), point2=(-5.0, 4.0), direction=COUNTERCLOCKWISE)

# 4. 拉伸成 3D 围岩实体
p = myModel.Part(name='Tunnel_Surrounding_Rock', dimensionality=THREE_D, type=DEFORMABLE_BODY)
p.BaseSolidExtrude(sketch=s, depth=20.0)
s.unsetPrimaryObject()

# 5. 装配
a = myModel.rootAssembly
a.DatumCsysByDefault(CARTESIAN)
a.Instance(name='Tunnel_Surrounding_Rock-1', part=p, dependent=ON)

# 6. 保存
cae_file_path = os.path.abspath("Auto_Generated_Tunnel.cae")
mdb.saveAs(pathName=cae_file_path)
print("=== 模型架构构建完成，.cae 工程文件已保存！ ===")
